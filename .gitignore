# Dependencies
node_modules/

# Build output
dist/
dist-native/
build/
out/

# Tauri
src-tauri/target/
src-tauri/gen/

# Capacitor — we DO commit the android/ scaffold so contributors can
# reproduce builds without reinstalling Android SDK packages. Only the
# per-build outputs need ignoring.
android/app/build/
android/.gradle/
android/build/
android/captures/
android/local.properties
android/app/release/
android/app/debug/
*.iml

# Gradle
.gradle/

# APK / AAB outputs
*.apk
*.aab

# Android signing keystores — NEVER commit. Keep local only.
# If lost, rotating an app's signing key on Google Play is painful,
# so back this up securely (password manager / encrypted vault).
*.keystore
*.jks

# Packaged desktop/mobile build artifacts. These go on GitHub Releases,
# not in the repo, to keep clone size sane.
builds/

# Vercel / deploy artifacts
.vercel/

# Env / secrets
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Vite cache
.vite/
node_modules/.vite/

# Local generator / experiment scratch (not part of the app)
output/
generate.cjs
generate_color.js
generate_from_image.cjs
generate_optimized.js
generate_scanlines.js
horse-*.svg
horse_generation_tutorial.md
run-turtle.ts
save-output-server.js
save-output-server.mjs
skillforthisprojectuse.md
vecteezy_*.svg
.agent/


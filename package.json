{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "//": "--- Web (default) ---",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "//native": "--- Native (Tauri + Capacitor shared) ---",
    "dev:native": "cross-env BUILD_TARGET=native vite --port 1420 --strictPort",
    "build:native": "cross-env BUILD_TARGET=native vite build",
    "//tauri": "--- Tauri desktop (Windows + Linux) ---",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "//android": "--- Capacitor Android ---",
    "android:init": "cap add android",
    "android:sync": "npm run build:native && cap sync android",
    "android:open": "cap open android",
    "android:build": "npm run build:native && cap sync android && cap run android --no-sync",
    "//misc": "--- Misc ---",
    "fetch-fonts": "powershell -ExecutionPolicy Bypass -File scripts/fetch-fonts.ps1"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/filesystem": "^8.0.0",
    "@capacitor/share": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.0.1",
    "@tauri-apps/plugin-fs": "^2.0.3",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@tailwindcss/vite": "4.1.17",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^22.0.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "cross-env": "^10.1.0",
    "tailwindcss": "4.1.17",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vite": "7.2.4",
    "vite-plugin-singlefile": "2.3.0"
  }
}

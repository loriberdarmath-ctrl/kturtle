{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "buildCommand": "npm run build && mkdir -p dist/about && cp -r docs/. dist/about/ && cp scripts/install-linux.sh dist/_install.sh",
  "outputDirectory": "dist",
  "framework": null,
  "trailingSlash": false,

  "rewrites": [
    { "source": "/",    "destination": "/about/index.html" },
    { "source": "/app", "destination": "/index.html" }
  ],

  "headers": [
    {
      "source": "/app",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/about/(.*)\\.(svg|png|jpg|jpeg|webp|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/_install.sh",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Content-Type",  "value": "text/x-shellscript; charset=utf-8" }
      ]
    }
  ]
}
